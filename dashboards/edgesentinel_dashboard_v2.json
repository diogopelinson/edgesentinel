      "title": "Taxa de inferências por segundo",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 24 },
      "options": {
        "legend": { "calcs": ["lastNotNull","sum"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 20, "gradientMode": "opacity" },
          "unit": "reqps"
        }
      },
      "targets": [{
        "expr": "rate(ai_service_inference_total[1m])",
        "legendFormat": "{{model_id}}", "refId": "A"
      }]
    },

    { "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 32 },
      "id": 104, "title": "Latência do pipeline (edgesentinel)", "type": "row" },

    {
      "id": 40, "type": "timeseries",
      "title": "Latência pipeline por sensor — P50 / P95",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 33 },
      "options": {
        "legend": { "calcs": ["lastNotNull","max"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10, "gradientMode": "opacity" },
          "unit": "s"
        }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, rate(edgesentinel_pipeline_latency_seconds_bucket[5m]))",
          "legendFormat": "P50 — {{sensor_id}}", "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, rate(edgesentinel_pipeline_latency_seconds_bucket[5m]))",
          "legendFormat": "P95 — {{sensor_id}}", "refId": "B"
        }
      ]
    },

    {
      "id": 41, "type": "timeseries",
      "title": "Latência de inferência edgesentinel — P50 / P95",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 33 },
      "options": {
        "legend": { "calcs": ["lastNotNull","max"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10, "gradientMode": "opacity" },
          "unit": "s"
        }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, rate(edgesentinel_inference_latency_seconds_bucket[5m]))",
          "legendFormat": "P50 — {{sensor_id}}", "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, rate(edgesentinel_inference_latency_seconds_bucket[5m]))",
          "legendFormat": "P95 — {{sensor_id}}", "refId": "B"
        }
      ]
    },

    {
      "id": 42, "type": "bargauge",
      "title": "Detecções AI Service (5m)",
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 41 },
      "options": {
        "displayMode": "gradient",
        "orientation": "horizontal",
        "reduceOptions": { "calcs": ["sum"] },
        "showUnfilled": true
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 10 },
              { "color": "red", "value": 50 }
            ]
          },
          "unit": "short"
        }
      },
      "targets": [{
        "expr": "increase(ai_service_detections_total[5m])",
        "legendFormat": "{{model_id}}", "refId": "A"
      }]
    }

  ],
  "refresh": "5s",
  "schemaVersion": 38,
  "tags": ["edgesentinel", "edge", "ml", "observability"],
